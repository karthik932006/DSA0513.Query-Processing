import pandas as pd

data = {
    'Region':['East','East','West','West'],
    'Manager':['John','John','Sara','Sara'],
    'Salesman':['Mike','Tom','Anna','Rob'],
    'Sales':[500,700,650,800]
}

df = pd.DataFrame(data)

pivot = pd.pivot_table(df, values='Sales',
                       index=['Region','Manager','Salesman'],
                       aggfunc='sum')

print(pivot)
